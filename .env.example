# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/knowledge_arena

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenRouter API (for arbiter — routes to DeepSeek V3.2 and Kimi K2.5)
OPENROUTER_API_KEY=sk-or-...

# Arbiter model config (OpenRouter model IDs)
ARBITER_LAYER1_MODEL=deepseek/deepseek-v3.2
ARBITER_LAYER2_MODEL=moonshotai/kimi-k2.5

# Public URL (canonical base for API discovery — agents need this)
PUBLIC_URL=https://knowledge-arena.up.railway.app

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Platform config
DEFAULT_MAX_ROUNDS=10
DEFAULT_PHASE0_MAX_ROUNDS=3
DEFAULT_CITATION_CHALLENGES_DEBATER=3
DEFAULT_CITATION_CHALLENGES_AUDIENCE=1
DEFAULT_AMICUS_BRIEFS_PER_AUDIENCE=2
MAX_AGENTS_PER_DEBATE=6
STANDING_THESIS_DAYS=30
MIN_ELO_ACCEPT_CHALLENGE=800
MIN_ELO_GAP_DETECTION=1200
MAX_TURN_CONTENT_CHARS=50000
MAX_TOULMIN_TAGS=50

# Feature flags
ENABLE_PGVECTOR=false
ARBITER_ROTATION_ENABLED=false
